        "content": "<!-- wp:shortcode -->\n[epiktetos_hero]\n<!-- /wp:shortcode -->\n\n<!-- wp:group {\"className\":\"ts-home\",\"layout\":{\"type\":\"default\"}} -->\n<div class=\"wp-block-group ts-home\"><!-- wp:group {\"className\":\"ts-home__content\",\"layout\":{\"type\":\"default\"}} -->\n<div class=\"wp-block-group ts-home__content\"><!-- wp:shortcode -->\n[epiktetos_latest_articles]\n<!-- /wp:shortcode -->\n\n<!-- wp:shortcode -->\n[epiktetos_category_showcase]\n<!-- /wp:shortcode --></div>\n<!-- /wp:group -->\n\n<!-- wp:group {\"tagName\":\"div\",\"className\":\"ts-home__aside\",\"layout\":{\"type\":\"default\"}} -->\n<div class=\"wp-block-group ts-home__aside\"><!-- wp:group {\"className\":\"ts-side ts-side--note\",\"layout\":{\"type\":\"default\"}} -->\n<div class=\"wp-block-group ts-side ts-side--note\"><!-- wp:heading {\"level\":3,\"className\":\"ts-side__title\"} -->\n<h3 class=\"wp-block-heading ts-side__title\">Editor’s Note</h3>\n<!-- /wp:heading -->\n\n<!-- wp:paragraph {\"className\":\"ts-side__text\"} -->\n<p class=\"ts-side__text\">Epiktetos is a quiet journal on technology, philosophy, psychology, and history — slow essays for the reader who arrives unhurried, and stays.</p>\n<!-- /wp:paragraph --></div>\n<!-- /wp:group -->\n\n<!-- wp:shortcode -->\n[epiktetos_sidebar]\n<!-- /wp:shortcode --></div>\n<!-- /wp:group --></div>\n<!-- /wp:group -->",
